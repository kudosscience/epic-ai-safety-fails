# Public Supabase project URL used by browser and server code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anonymous key used by browser Supabase client.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key used only by server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public reCAPTCHA site key used by the signup form.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Secret reCAPTCHA key used by server-side verification.
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
